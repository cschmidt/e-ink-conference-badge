# Copy to .env and fill in real values

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Comma-separated Telegram chat IDs allowed to update the badge
# Leave empty to allow anyone (not recommended for production)
TELEGRAM_ALLOWED_CHAT_IDS=

# Anthropic API key (for Claude Vision)
ANTHROPIC_API_KEY=sk-ant-...

# Badge owner defaults
BADGE_NAME=Carl Schmidt
BADGE_TITLE=AI Advisor
BADGE_COMPANY=
BADGE_EVENT=ACETECH 2026

# QR code defaults
DEFAULT_QR_URL=https://carlschmidt.ca
DEFAULT_QR_LABEL=carlschmidt.ca

# Flask
FLASK_DEBUG=false
SECRET_KEY=change-me-in-production

# MQTT broker (on mabel/TrueNAS, public via clara.schmidthaus.ca)
# Leave MQTT_BROKER empty to disable MQTT publishing (polling-only mode)
MQTT_BROKER=clara.schmidthaus.ca
MQTT_PORT=1883
MQTT_USER=badger
MQTT_PASSWORD=your-mqtt-password
MQTT_TOPIC=badge/carl/display
